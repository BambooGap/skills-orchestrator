{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/BambooGap/skills-orchestrator/schemas/evidence-bundle.schema.json",
  "title": "Skills Orchestrator Evidence Bundle",
  "type": "object",
  "required": ["schema_version", "config", "zone", "policy_packs", "files"],
  "properties": {
    "schema_version": { "const": "skills-orchestrator.evidence-bundle.v1" },
    "config": { "type": "string" },
    "zone": { "type": "string" },
    "policy_packs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "files": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "ledger": {
      "type": "object",
      "required": ["artifact_hashes", "previous_bundle_hash", "bundle_hash"],
      "properties": {
        "artifact_hashes": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/artifact_hash" }
        },
        "previous_bundle_hash": { "type": "string" },
        "bundle_hash": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true,
  "$defs": {
    "artifact_hash": {
      "type": "object",
      "required": ["alg", "value", "path"],
      "properties": {
        "alg": { "const": "SHA-256" },
        "value": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "path": { "type": "string" }
      },
      "additionalProperties": true
    }
  }
}
