{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/BambooGap/skills-orchestrator/schemas/skills-config.schema.json",
  "title": "Skills Orchestrator Config",
  "type": "object",
  "properties": {
    "version": {
      "type": ["string", "number"]
    },
    "skill_dirs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "overrides": {
      "type": "array",
      "items": { "$ref": "#/$defs/skillOverride" }
    },
    "zones": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/zone" }
    },
    "skills": {
      "type": "array",
      "items": { "$ref": "#/$defs/skill" }
    },
    "combos": {
      "type": "array",
      "items": { "$ref": "#/$defs/combo" }
    }
  },
  "additionalProperties": true,
  "$defs": {
    "stringList": {
      "type": "array",
      "items": { "type": "string" }
    },
    "rule": {
      "type": "object",
      "anyOf": [
        { "required": ["pattern"] },
        { "required": ["git_contains"] }
      ],
      "properties": {
        "pattern": { "type": "string" },
        "git_contains": { "type": "string" }
      },
      "additionalProperties": true
    },
    "zone": {
      "type": "object",
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "load_policy": { "enum": ["require", "exclusive", "free"] },
        "priority": { "type": "integer", "minimum": 0, "maximum": 999 },
        "rules": {
          "type": "array",
          "items": { "$ref": "#/$defs/rule" }
        },
        "skills": { "$ref": "#/$defs/stringList" },
        "allow_base_skills": { "$ref": "#/$defs/stringList" }
      },
      "additionalProperties": true
    },
    "skill": {
      "type": "object",
      "required": ["id", "name", "path", "summary"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "summary": { "type": "string" },
        "tags": { "$ref": "#/$defs/stringList" },
        "load_policy": { "enum": ["require", "free"] },
        "priority": { "type": "integer", "minimum": 0, "maximum": 999 },
        "zones": { "$ref": "#/$defs/stringList" },
        "conflict_with": { "$ref": "#/$defs/stringList" },
        "base": { "type": "string" },
        "owner": { "type": "string" },
        "source": { "type": "string" },
        "version": { "type": "string" },
        "lifecycle": { "enum": ["active", "beta", "deprecated", "retired"] },
        "approvers": { "$ref": "#/$defs/stringList" },
        "reviewed_at": { "type": "string" },
        "expires_at": { "type": "string" },
        "license": { "type": "string" },
        "provenance": {
          "type": "object",
          "additionalProperties": { "type": ["string", "number", "boolean", "null"] }
        }
      },
      "additionalProperties": true
    },
    "skillOverride": {
      "type": "object",
      "required": ["id"],
      "properties": {
        "id": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    },
    "combo": {
      "type": "object",
      "required": ["id", "name"],
      "anyOf": [
        { "required": ["members"] },
        { "required": ["skills"] }
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "members": { "$ref": "#/$defs/stringList" },
        "skills": { "$ref": "#/$defs/stringList" },
        "description": { "type": "string" }
      },
      "additionalProperties": true
    }
  }
}
