{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/BambooGap/skills-orchestrator/schemas/post-release-smoke.schema.json",
  "title": "Skills Orchestrator Post-release Smoke Report",
  "type": "object",
  "required": ["schema_version", "status", "summary", "checks"],
  "properties": {
    "schema_version": { "const": "skills-orchestrator.post-release-smoke.v1" },
    "status": { "enum": ["pass", "fail"] },
    "summary": {
      "type": "object",
      "required": ["passed", "failed"],
      "properties": {
        "passed": { "type": "integer", "minimum": 0 },
        "failed": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "ok", "message"],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          },
          "ok": { "type": "boolean" },
          "message": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
