{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/BambooGap/skills-orchestrator/schemas/schema-catalog.schema.json",
  "title": "Skills Orchestrator Schema Catalog",
  "type": "object",
  "required": ["schema_version", "schemas"],
  "properties": {
    "schema_version": { "const": "skills-orchestrator.schema-catalog.v1" },
    "schemas": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "kind",
          "title",
          "description",
          "file",
          "contract_id",
          "stability",
          "since",
          "consumers"
        ],
        "properties": {
          "kind": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          },
          "title": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 },
          "file": {
            "type": "string",
            "pattern": "^[A-Za-z0-9_.-]+\\.schema\\.json$"
          },
          "contract_id": { "type": "string", "minLength": 1 },
          "stability": { "enum": ["stable", "preview"] },
          "since": {
            "type": "string",
            "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$"
          },
          "consumers": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^[a-z0-9][a-z0-9-]*$"
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
