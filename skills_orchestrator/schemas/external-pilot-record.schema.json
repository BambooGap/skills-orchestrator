{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/BambooGap/skills-orchestrator/schemas/external-pilot-record.schema.json",
  "title": "Skills Orchestrator External Pilot Record",
  "type": "object",
  "required": ["schema_version", "pilot", "gate", "artifacts", "promotion", "public_listing"],
  "properties": {
    "schema_version": { "const": "skills-orchestrator.external-pilot-record.v1" },
    "pilot": {
      "type": "object",
      "required": ["repository", "pilot_owner", "started_at", "skillops_version", "ci_system"],
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 3,
          "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
        },
        "pilot_owner": { "type": "string", "minLength": 1 },
        "started_at": { "type": "string", "minLength": 1 },
        "skillops_version": {
          "type": "string",
          "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "ci_system": { "type": "string", "minLength": 1 },
        "notes": { "type": "string" }
      },
      "additionalProperties": true
    },
    "gate": {
      "type": "object",
      "required": ["mode", "policy_pack"],
      "properties": {
        "mode": {
          "enum": ["advisory", "warning", "engineering", "release-gate", "stopped"]
        },
        "policy_pack": { "type": "string", "minLength": 1 },
        "fail_on": { "enum": ["none", "error", "warning"] }
      },
      "additionalProperties": true
    },
    "artifacts": {
      "type": "object",
      "required": [
        "check_json",
        "sarif",
        "registry_diff",
        "evidence_manifest",
        "conformance_report"
      ],
      "properties": {
        "check_json": { "$ref": "#/$defs/artifact" },
        "sarif": { "$ref": "#/$defs/artifact" },
        "registry_diff": { "$ref": "#/$defs/artifact" },
        "ci_explainability": { "$ref": "#/$defs/artifact" },
        "reviewer_summary": { "$ref": "#/$defs/artifact" },
        "dashboard_snapshot": { "$ref": "#/$defs/artifact" },
        "evidence_manifest": { "$ref": "#/$defs/artifact" },
        "conformance_report": { "$ref": "#/$defs/artifact" }
      },
      "additionalProperties": { "$ref": "#/$defs/artifact" }
    },
    "promotion": {
      "type": "object",
      "required": ["decision", "decided_at"],
      "properties": {
        "decision": {
          "enum": [
            "stay-advisory",
            "promote-warning",
            "promote-engineering",
            "promote-release-gate",
            "stop-pilot"
          ]
        },
        "decided_at": { "type": "string", "minLength": 1 },
        "next_review": { "type": "string" },
        "reviewer": { "type": "string" },
        "rationale": { "type": "string" },
        "stop_conditions": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": true
    },
    "public_listing": {
      "type": "object",
      "required": ["status"],
      "properties": {
        "status": { "enum": ["not-requested", "denied", "approved"] },
        "approved_by": { "type": "string", "minLength": 1 },
        "approved_at": { "type": "string", "minLength": 1 },
        "notes": { "type": "string" }
      },
      "allOf": [
        {
          "if": {
            "properties": { "status": { "const": "approved" } },
            "required": ["status"]
          },
          "then": { "required": ["approved_by", "approved_at"] }
        }
      ],
      "additionalProperties": true
    }
  },
  "additionalProperties": true,
  "$defs": {
    "artifact": {
      "type": "object",
      "required": ["status"],
      "properties": {
        "status": { "enum": ["present", "missing", "not-applicable"] },
        "path": { "$ref": "#/$defs/bundleRelativePath" },
        "notes": { "type": "string" }
      },
      "allOf": [
        {
          "if": {
            "properties": { "status": { "const": "present" } },
            "required": ["status"]
          },
          "then": { "required": ["path"] }
        }
      ],
      "additionalProperties": true
    },
    "bundleRelativePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?![A-Za-z][A-Za-z0-9+.-]*:)(?!.*(^|/)\\.\\.($|/))(?!.*\\\\)[A-Za-z0-9._/-]+$"
    }
  }
}
