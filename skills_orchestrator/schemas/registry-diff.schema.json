{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/BambooGap/skills-orchestrator/schemas/registry-diff.schema.json",
  "title": "Skills Orchestrator Registry Diff",
  "type": "object",
  "required": ["schema_version", "summary", "added", "removed", "changed", "duplicate_id_changes"],
  "properties": {
    "schema_version": { "const": "skills-orchestrator.registry-diff.v1" },
    "summary": {
      "type": "object",
      "required": ["added", "removed", "changed", "duplicate_id_changes"],
      "additionalProperties": { "type": "integer" }
    },
    "added": {
      "type": "array",
      "items": { "$ref": "#/$defs/skill" }
    },
    "removed": {
      "type": "array",
      "items": { "$ref": "#/$defs/skill" }
    },
    "changed": {
      "type": "array",
      "items": { "$ref": "#/$defs/changedSkill" }
    },
    "duplicate_id_changes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "before", "after"],
        "properties": {
          "id": { "type": "string" },
          "before": { "type": "integer" },
          "after": { "type": "integer" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true,
  "$defs": {
    "skill": {
      "type": "object",
      "required": ["registry_key", "id", "name", "status", "path", "governance", "content_hash", "missing_file"],
      "properties": {
        "governance": { "$ref": "#/$defs/governance" }
      },
      "additionalProperties": true
    },
    "changedSkill": {
      "type": "object",
      "required": ["registry_key", "id", "changes"],
      "properties": {
        "registry_key": { "type": "string" },
        "id": { "type": "string" },
        "skill": { "$ref": "#/$defs/changedSkillSnapshot" },
        "changes": { "type": "object" }
      },
      "additionalProperties": true
    },
    "changedSkillSnapshot": {
      "type": "object",
      "required": ["name", "status", "path", "governance"],
      "properties": {
        "name": { "type": "string" },
        "status": { "type": "string" },
        "path": { "type": "string" },
        "governance": { "$ref": "#/$defs/governance" }
      },
      "additionalProperties": true
    },
    "governance": {
      "type": "object",
      "properties": {
        "owner": { "type": "string" },
        "source": { "type": "string" },
        "version": { "type": "string" },
        "lifecycle": { "type": "string" },
        "approvers": {
          "type": "array",
          "items": { "type": "string" }
        },
        "reviewed_at": { "type": "string" },
        "expires_at": { "type": "string" },
        "license": { "type": "string" },
        "provenance": { "$ref": "#/$defs/provenance" }
      },
      "additionalProperties": true
    },
    "provenance": {
      "type": "object",
      "properties": {
        "source_url": { "type": "string" },
        "source_ref": { "type": "string" },
        "source_commit": { "type": "string" },
        "content_hash": { "type": "string" },
        "fetched_at": { "type": "string" }
      },
      "additionalProperties": { "type": ["string", "number", "boolean", "null"] }
    }
  }
}
