{
  "schema_version": "skills-orchestrator.agent-handoff.v1",
  "handoff": {
    "id": "production-without-explainability",
    "mode": "triage-handoff",
    "created_at": "2026-06-28T00:00:00Z",
    "owner": "platform-ai",
    "status": "authorized"
  },
  "tenant_scope": {
    "provider": "internal",
    "tenant": "payments",
    "project": "payments-prod",
    "environment": "production"
  },
  "supervisor": {
    "id": "release-lead",
    "role": "Delegate production release review work.",
    "allowed_actions": ["plan", "delegate", "evaluate", "reject"]
  },
  "workers": [
    {
      "id": "readonly-reviewer",
      "purpose": "This worker is intentionally invalid because production handoffs need CI explainability evidence.",
      "agent_surface": "codex",
      "permission_mode": "read-only",
      "requires_human_approval": false,
      "allowed_tools": ["Read", "Grep"],
      "denied_tools": ["Write", "Edit", "Bash"],
      "context": {
        "isolation": "isolated",
        "allowed_inputs": ["evidence/evidence-manifest.json"],
        "forbidden_inputs": ["tenant-secrets", "customer-data"]
      },
      "required_outputs": ["risk_summary", "evidence_paths"]
    }
  ],
  "task": {
    "id": "production-review-without-explainability",
    "summary": "Invalid production evidence fixture.",
    "scope": "production release candidate only",
    "inputs": [
      {
        "kind": "evidence-manifest",
        "path": "evidence/evidence-manifest.json"
      }
    ],
    "expected_outputs": ["risk_summary"],
    "stop_condition": "Never run this fixture."
  },
  "evidence": {
    "required_artifacts": ["evidence-manifest"],
    "produced_artifacts": [
      {
        "kind": "agent-handoff",
        "path": "examples/agent-handoff/invalid-production-evidence.json"
      }
    ]
  },
  "evaluation": {
    "required": true,
    "gates": ["policy-check", "schema-validate", "human-review"]
  }
}
